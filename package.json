{
  "name": "ynote",
  "displayName": "YNote - Reading Record",
  "description": "A private reading record system for recording daily reading material with abstracts and metadata.",
  "version": "0.2.1",
  "publisher": "yanfeit",
  "extensionKind": [
    "workspace"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yanfeit/ynote"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "ynote.addReading",
        "title": "YNote: Add Reading from URL",
        "icon": "$(add)"
      },
      {
        "command": "ynote.removeReading",
        "title": "YNote: Remove Reading",
        "icon": "$(trash)"
      },
      {
        "command": "ynote.openReading",
        "title": "YNote: Open in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "ynote.showDashboard",
        "title": "YNote: Show Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "ynote.syncToGithub",
        "title": "YNote: Push to GitHub",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "ynote.pullFromGithub",
        "title": "YNote: Pull from GitHub",
        "icon": "$(cloud-download)"
      },
      {
        "command": "ynote.refreshReadings",
        "title": "YNote: Refresh Readings",
        "icon": "$(refresh)"
      },
      {
        "command": "ynote.editTags",
        "title": "YNote: Edit Tags",
        "icon": "$(tag)"
      },
      {
        "command": "ynote.createNote",
        "title": "YNote: Create Note",
        "icon": "$(add)"
      },
      {
        "command": "ynote.openNote",
        "title": "YNote: Open Note",
        "icon": "$(edit)"
      },
      {
        "command": "ynote.removeNote",
        "title": "YNote: Remove Note",
        "icon": "$(trash)"
      },
      {
        "command": "ynote.editNoteTags",
        "title": "YNote: Edit Note Tags",
        "icon": "$(tag)"
      },
      {
        "command": "ynote.refreshNotes",
        "title": "YNote: Refresh Notes",
        "icon": "$(refresh)"
      },
      {
        "command": "ynote.cutReading",
        "title": "YNote: Cut Reading"
      },
      {
        "command": "ynote.copyReading",
        "title": "YNote: Copy Reading URL"
      },
      {
        "command": "ynote.renameReading",
        "title": "YNote: Rename Reading"
      },
      {
        "command": "ynote.deleteReading",
        "title": "YNote: Permanent Delete Reading",
        "icon": "$(trash)"
      },
      {
        "command": "ynote.downloadReading",
        "title": "YNote: Download Reading"
      },
      {
        "command": "ynote.cutNote",
        "title": "YNote: Cut Note"
      },
      {
        "command": "ynote.copyNote",
        "title": "YNote: Copy Note Content"
      },
      {
        "command": "ynote.renameNote",
        "title": "YNote: Rename Note"
      },
      {
        "command": "ynote.deleteNote",
        "title": "YNote: Permanent Delete Note",
        "icon": "$(trash)"
      },
      {
        "command": "ynote.downloadNote",
        "title": "YNote: Download Note"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ynote",
          "title": "YNote",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "ynote": [
        {
          "id": "ynoteReadings",
          "name": "My Reading Diary",
          "icon": "$(book)",
          "contextualTitle": "YNote Readings"
        },
        {
          "id": "ynoteNotes",
          "name": "Notes",
          "icon": "$(note)",
          "contextualTitle": "YNote Notes"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "ynote.addReading",
          "when": "view == ynoteReadings",
          "group": "navigation@1"
        },
        {
          "command": "ynote.syncToGithub",
          "when": "view == ynoteReadings",
          "group": "navigation@2"
        },
        {
          "command": "ynote.pullFromGithub",
          "when": "view == ynoteReadings",
          "group": "navigation@3"
        },
        {
          "command": "ynote.refreshReadings",
          "when": "view == ynoteReadings",
          "group": "navigation@4"
        },
        {
          "command": "ynote.showDashboard",
          "when": "view == ynoteReadings",
          "group": "navigation@5"
        },
        {
          "command": "ynote.createNote",
          "when": "view == ynoteNotes",
          "group": "navigation@1"
        },
        {
          "command": "ynote.syncToGithub",
          "when": "view == ynoteNotes",
          "group": "navigation@2"
        },
        {
          "command": "ynote.pullFromGithub",
          "when": "view == ynoteNotes",
          "group": "navigation@3"
        },
        {
          "command": "ynote.refreshNotes",
          "when": "view == ynoteNotes",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "ynote.openReading",
          "when": "view == ynoteReadings && viewItem == reading",
          "group": "0_open@1"
        },
        {
          "command": "ynote.cutReading",
          "when": "view == ynoteReadings && viewItem == reading",
          "group": "1_clipboard@1"
        },
        {
          "command": "ynote.copyReading",
          "when": "view == ynoteReadings && viewItem == reading",
          "group": "1_clipboard@2"
        },
        {
          "command": "ynote.renameReading",
          "when": "view == ynoteReadings && viewItem == reading",
          "group": "2_edit@1"
        },
        {
          "command": "ynote.editTags",
          "when": "view == ynoteReadings && viewItem == reading",
          "group": "2_edit@2"
        },
        {
          "command": "ynote.deleteReading",
          "when": "view == ynoteReadings && viewItem == reading",
          "group": "3_manage@1"
        },
        {
          "command": "ynote.downloadReading",
          "when": "view == ynoteReadings && viewItem == reading",
          "group": "3_manage@2"
        },
        {
          "command": "ynote.openNote",
          "when": "view == ynoteNotes && viewItem == note",
          "group": "0_open@1"
        },
        {
          "command": "ynote.cutNote",
          "when": "view == ynoteNotes && viewItem == note",
          "group": "1_clipboard@1"
        },
        {
          "command": "ynote.copyNote",
          "when": "view == ynoteNotes && viewItem == note",
          "group": "1_clipboard@2"
        },
        {
          "command": "ynote.renameNote",
          "when": "view == ynoteNotes && viewItem == note",
          "group": "2_edit@1"
        },
        {
          "command": "ynote.editNoteTags",
          "when": "view == ynoteNotes && viewItem == note",
          "group": "2_edit@2"
        },
        {
          "command": "ynote.deleteNote",
          "when": "view == ynoteNotes && viewItem == note",
          "group": "3_manage@1"
        },
        {
          "command": "ynote.downloadNote",
          "when": "view == ynoteNotes && viewItem == note",
          "group": "3_manage@2"
        }
      ]
    },
    "configuration": {
      "title": "YNote",
      "properties": {
        "ynote.githubRepoUrl": {
          "type": "string",
          "default": "",
          "description": "Private GitHub repository URL for syncing readings (e.g., git@github.com:user/ynote-data.git)"
        },
        "ynote.maxAbstractLength": {
          "type": "number",
          "default": 500,
          "description": "Maximum length of extracted abstract text"
        },
        "ynote.fallbackDescriptionLength": {
          "type": "number",
          "default": 100,
          "description": "Fallback description length when no abstract is found"
        },
        "ynote.fetchTimeout": {
          "type": "number",
          "default": 10000,
          "description": "Timeout in milliseconds for fetching web page metadata"
        }
      }
    },
    "keybindings": [
      {
        "command": "ynote.addReading",
        "key": "ctrl+shift+y",
        "mac": "cmd+shift+y"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit",
    "test": "npm run compile && mocha 'out/test/**/*.test.js' --timeout 10000"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.110.0",
    "mocha": "^11.7.5",
    "typescript": "^6.0.2"
  }
}
